{
  "name": "@open-resource-discovery/provider-server",
  "version": "1.2.3",
  "description": "A CLI application or server that takes multiple ORD documents and other metadata files and exposes them as a ORD Provider implementation (ORD Document API)",
  "engines": {
    "node": ">=24.10.7",
    "npm": ">=11.6.1"
  },
  "type": "module",
  "bin": "dist/cli.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "prebuild": "rimraf ./dist",
    "build": "tsc -p tsconfig.prod.json && tsc-alias -p tsconfig.prod.json",
    "prepublishOnly": "npm run build",
    "deploy": "npm run build && npm prune --production && cf login -a https://api.cf.sap.hana.ondemand.com -o CORE_CF -s open-discovery && cf push && npm install",
    "start": "node dist/cli.js",
    "dev": "tsx watch ./src/cli.ts",
    "eslint": "eslint . --fix",
    "eslint:ci": "eslint .",
    "prettier": "prettier --write \"**/*.{json,yml,yaml,md}\"",
    "prettier:ci": "prettier --check \"**/*.{json,yml,yaml,md}\"",
    "format": "npm run prettier && npm run eslint",
    "test:ci": "jest --ci --collectCoverage",
    "test:watch": "jest --watchAll",
    "test": "npm run test:ci",
    "coverage": "jest --coverage --maxWorkers=1",
    "prepare": "[ ! -z \"$CF_INSTANCE_IP\" ] || is-ci || husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-resource-discovery/provider-server.git"
  },
  "author": "SAP SE",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/auth": "5.0.4",
    "@fastify/basic-auth": "6.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/etag": "6.1.0",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "11.2.0",
    "@octokit/rest": "22.0.1",
    "@open-resource-discovery/specification": "1.16.2",
    "bcryptjs": "3.0.3",
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-plugin": "6.0.0",
    "fastify-raw-body": "5.0.0",
    "isomorphic-git": "1.38.5",
    "p-limit": "7.3.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  },
  "devDependencies": {
    "@sap/eslint-config": "0.5.2",
    "@tsconfig/node24": "24.0.4",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "@types/ws": "8.18.1",
    "eslint": "10.6.0",
    "fetch-mock": "12.6.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jest": "30.4.2",
    "jest-cli": "30.4.2",
    "jest-fetch-mock": "3.0.3",
    "jest-junit": "17.0.0",
    "jest-watch-typeahead": "3.0.1",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.11",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "./**/*.{js,ts}": [
      "eslint --quiet"
    ],
    "**/*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "test-exclude": "8.0.0",
    "glob": "13.0.6",
    "form-data": "4.0.6",
    "js-yaml": "4.2.0",
    "esbuild": "0.28.1"
  }
}
